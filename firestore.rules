rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }

    function isStringField(value, max) {
      return value is string && value.size() <= max;
    }

    function isOptionalStringField(data, key, max) {
      return !(key in data) || isStringField(data[key], max);
    }

    function validProfile(data) {
      return data.keys().hasAll([
        'planId',
        'subscriptionStatus',
        'monthlyGenerationLimit',
        'usedGenerationsThisPeriod',
        'currentPeriodStart',
        'currentPeriodEnd',
        'updatedAt'
      ]) &&
      isStringField(data.planId, 32) &&
      isStringField(data.subscriptionStatus, 32) &&
      data.monthlyGenerationLimit is int &&
      data.usedGenerationsThisPeriod is int &&
      isStringField(data.currentPeriodStart, 64) &&
      isStringField(data.currentPeriodEnd, 64) &&
      isStringField(data.updatedAt, 64) &&
      isOptionalStringField(data, 'stripeCustomerId', 128) &&
      isOptionalStringField(data, 'stripeSubscriptionId', 128) &&
      isOptionalStringField(data, 'lastCheckoutSessionId', 128);
    }

    function validService(data) {
      return data.keys().hasAll([
        'serviceType',
        'displayName',
        'encryptedSecrets',
        'isActive',
        'priority',
        'createdAt',
        'updatedAt'
      ]) &&
      isStringField(data.serviceType, 32) &&
      isStringField(data.displayName, 128) &&
      isStringField(data.encryptedSecrets, 4096) &&
      data.isActive is bool &&
      data.priority is int &&
      isStringField(data.createdAt, 64) &&
      isStringField(data.updatedAt, 64) &&
      isOptionalStringField(data, 'senderName', 128) &&
      isOptionalStringField(data, 'senderEmail', 256) &&
      isOptionalStringField(data, 'smtpProvider', 32) &&
      isOptionalStringField(data, 'smtpHost', 256) &&
      isOptionalStringField(data, 'smtpPort', 8) &&
      isOptionalStringField(data, 'smtpUser', 256) &&
      (!( 'dailyCount' in data) || data.dailyCount is int) &&
      (!( 'monthlyCount' in data) || data.monthlyCount is int) &&
      isOptionalStringField(data, 'dailyKey', 32) &&
      isOptionalStringField(data, 'monthlyKey', 32) &&
      isOptionalStringField(data, 'lastSuccessAt', 64) &&
      isOptionalStringField(data, 'lastFailureAt', 64) &&
      isOptionalStringField(data, 'lastFailureReason', 512);
    }

    match /users/{userId} {
      match /profile/{profileId} {
        allow get, list: if isOwner(userId);
        allow create, update: if isOwner(userId) && validProfile(incoming());
      }

      match /emailServices/{serviceId} {
        allow get, list: if isOwner(userId);
        allow create, update: if isOwner(userId) && validService(incoming());
        allow delete: if isOwner(userId);
      }
    }
  }
}
