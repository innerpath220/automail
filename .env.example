# AI generation
AI_PROVIDER=groq
GROQ_API_KEY="MY_GROQ_API_KEY"
GROQ_MODEL=llama-3.3-70b-versatile

# Required for encrypting per-user provider credentials at rest
SMTP_SETTINGS_ENCRYPTION_KEY=

# App URL used by Stripe redirects
APP_URL=http://localhost:3000

# Stripe subscription billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=

# Optional legacy SMTP fallback env vars if you still want a global server account
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
